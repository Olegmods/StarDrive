{
    "version": "2.0.0",
    "options": {
        "env": {
            "MSBUILD": "C:\\Program Files\\Microsoft Visual Studio\\2022\\Community\\MSBuild\\Current\\Bin\\MSBuild.exe"
        }
    },
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "${env:MSBUILD}",
            "args": [
                "StarDrive.sln",
                "/p:Configuration=Debug",
                "/p:Platform=x86",
                "/m",
                "/verbosity:minimal",
                "/nologo"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "build x86 Release",
            "type": "shell",
            "command": "${env:MSBUILD}",
            "args": [
                "StarDrive.sln",
                "/p:Configuration=Release",
                "/p:Platform=x86",
                "/m",
                "/verbosity:minimal",
                "/nologo"
            ],
            "group": "build",
            "problemMatcher": [
                "$msCompile"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "build x64 Debug",
            "type": "shell",
            "command": "${env:MSBUILD}",
            "args": [
                "StarDrive.sln",
                "/p:Configuration=Debug",
                "/p:Platform=x64",
                "/m",
                "/verbosity:minimal",
                "/nologo"
            ],
            "group": "build",
            "problemMatcher": [
                "$msCompile"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "build x64 Release",
            "type": "shell",
            "command": "${env:MSBUILD}",
            "args": [
                "StarDrive.sln",
                "/p:Configuration=Release",
                "/p:Platform=x64",
                "/m",
                "/verbosity:minimal",
                "/nologo"
            ],
            "group": "build",
            "problemMatcher": [
                "$msCompile"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "rebuild x86 Debug",
            "type": "shell",
            "command": "${env:MSBUILD}",
            "args": [
                "StarDrive.sln",
                "/t:Rebuild",
                "/p:Configuration=Debug",
                "/p:Platform=x86",
                "/m",
                "/verbosity:minimal",
                "/nologo"
            ],
            "group": "build",
            "problemMatcher": [
                "$msCompile"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "clean",
            "type": "shell",
            "command": "${env:MSBUILD}",
            "args": [
                "StarDrive.sln",
                "/t:Clean",
                "/p:Configuration=Debug",
                "/p:Platform=x86",
                "/verbosity:minimal",
                "/nologo"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "restore packages",
            "type": "shell",
            "command": "${env:MSBUILD}",
            "args": [
                "StarDrive.sln",
                "/t:Restore",
                "/verbosity:minimal",
                "/nologo"
            ],
            "group": "build",
            "problemMatcher": []
        }
    ]
}
