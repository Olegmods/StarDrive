  </ItemGroup>

  <!-- Phase 2.6.A: dropped polyfill / now-built-in packages —
       IsExternalInit, Microsoft.Win32.Registry, System.Reflection.Metadata,
       System.Security.AccessControl, System.Text.Json all ship with net8.
       WiX (installer-only) belongs in Deploy/, not the runtime build. -->

  <!--
    Deploy-only post-build: produce the major NSIS installer into Deploy\upload\
    for manual upload to itch.io. Patches go through the separate
    patch-build.yml workflow on push-to-main + workflow_dispatch — they
    don't share this code path.

    Was a <PostBuildEvent> with $(ConfigurationName) on the Mars line;
    SDK-style C# csproj resolves $(ConfigurationName) to empty (only
    $(Configuration) is set), and `::` comments inside cmd `if (…)` blocks
    parse as commands — both broke the post-build under msbuild Deploy|x64.
    Switched to a MSBuild Target with a Condition for clarity + correctness.

    ZIP is intentionally skipped here — MakeInstaller.py chunks ZIPs at
    25 MB unconditionally (right for the in-game patch updater, wrong for
    an itch.io single-file ZIP).
  -->
  <Target Name="MakeMajorInstaller" AfterTargets="Build" Condition="'$(Configuration)' == 'Deploy'">
    <!-- Use $(MSBuildProjectDirectory), not $(SolutionDir): when msbuild is
         pointed at the .csproj directly (not the .sln), $(SolutionDir) is
         literal *Undefined* and the post-build crashes. The repo root is
         where the .csproj lives. -->
    <Exec Command="py -3 &quot;$(MSBuildProjectDirectory)\Deploy\MakeInstaller.py&quot; --root_dir &quot;$(MSBuildProjectDirectory)&quot; --major --type=nsis" />
  </Target>

